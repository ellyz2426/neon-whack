<style>
  .shop-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3;
    background-color: rgba(0, 0, 0, 0.92);
    border-color: #ff4400;
    border-width: 0.12;
    border-radius: 2;
    gap: 0.8;
  }
  .shop-title {
    font-size: 3;
    color: #ff4400;
    font-weight: bold;
  }
  .shop-grid {
    display: flex;
    flex-direction: column;
    gap: 0.6;
  }
  .shop-item {
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 0.6 2;
    background-color: rgba(255, 68, 0, 0.12);
    border-color: #442211;
    border-width: 0.06;
    border-radius: 0.8;
    gap: 1.5;
    cursor: pointer;
    min-width: 30;
  }
  .shop-item:hover {
    background-color: rgba(255, 68, 0, 0.3);
  }
  .shop-name {
    font-size: 1.4;
    color: #ff6633;
    font-weight: bold;
  }
  .back-btn {
